<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">
    <fragment
        android:id="@+id/favoritoFragment"
        android:name="com.example.practicaexamen.ui.fragment.FavoritoFragment"
        android:label="FavoritoFragment" />
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.practicaexamen.ui.fragment.LoginFragment"
        android:label="LoginFragment" >
        <action
            android:id="@+id/action_loginFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
    </fragment>
    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.practicaexamen.ui.fragment.MainFragment"
        android:label="MainFragment" >
        <action
            android:id="@+id/action_mainFragment_to_favoritoFragment"
            app:destination="@id/favoritoFragment" />
    </fragment>
</navigation>