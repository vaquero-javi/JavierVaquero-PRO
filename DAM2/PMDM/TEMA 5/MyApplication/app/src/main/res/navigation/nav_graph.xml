<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">
    <dialog
        android:id="@+id/dialogRegisterFAIL"
        android:name="com.example.myapplication.ui.dialog.DialogRegisterFAIL"
        android:label="DialogRegisterFAIL" />
    <dialog
        android:id="@+id/dialogRegisterOK"
        android:name="com.example.myapplication.ui.dialog.DialogRegisterOK"
        android:label="DialogRegisterOK" >
        <action
            android:id="@+id/action_dialogRegisterOK_to_mainFragment"
            app:destination="@id/mainFragment" />
        <action
            android:id="@+id/action_dialogRegisterOK_to_loginFragment"
            app:destination="@id/loginFragment" />
    </dialog>
    <fragment
        tools:layout="@layout/fragment_login"
        android:id="@+id/loginFragment"
        android:name="com.example.myapplication.ui.fragment.LoginFragment"
        android:label="LoginFragment" >
        <action
            android:id="@+id/action_loginFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>
    <fragment
        tools:layout="@layout/fragment_main"
        android:id="@+id/mainFragment"
        android:name="com.example.myapplication.ui.fragment.MainFragment"
        android:label="MainFragment" />
    <fragment
        tools:layout="@layout/fragment_register"
        android:id="@+id/registerFragment"
        android:name="com.example.myapplication.ui.fragment.RegisterFragment"
        android:label="RegisterFragment" >
        <action
            android:id="@+id/action_registerFragment_to_dialogRegisterFAIL"
            app:destination="@id/dialogRegisterFAIL" />
        <action
            android:id="@+id/action_registerFragment_to_dialogRegisterOK"
            app:destination="@id/dialogRegisterOK" />
        <argument
            android:name="nombre"
            app:argType="string" />
        <argument
            android:name="pass"
            app:argType="string" />
    </fragment>
</navigation>